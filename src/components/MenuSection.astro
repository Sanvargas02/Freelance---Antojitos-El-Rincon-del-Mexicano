---
import MenuItemCard from './MenuItemCard.astro';
import { menuItems } from '../data/menu';

const lambBarbacoaItems = menuItems.filter((item) =>
  ['Barbacoa', 'Consomme', 'Lunch'].includes(item.category)
);
const huarachesItems = menuItems.filter((item) => item.category === 'Huaraches');
const tlacoyosItems = menuItems.filter((item) => item.category === 'Tlacoyos');
const porkCarnitasItems = menuItems.filter((item) => item.category === 'Pork Carnitas');
const grilledPlatterItems = menuItems.filter((item) => item.category === 'Grilled Platter CDMX');
const dessertsItems = menuItems.filter((item) => item.category === 'Desserts');
const drinksItems = menuItems.filter((item) => item.category === 'Drinks');
---

<section id="menu" class="menu-section">
  <div class="menu-header">
    <h2 class="menu-title">Our Antojitos</h2>
    <div class="menu-flag">🇲🇽</div>
  </div>

  <div class="menu-subtitle-wrap">
    <h3 class="menu-subtitle">LAMB BARBACOA</h3>
    <p class="menu-subtitle-text">Traditional lamb barbacoa and consomme specials.</p>
  </div>
  <div class="menu-grid">
    {lambBarbacoaItems.map((item) => (
      <MenuItemCard item={item} />
    ))}
  </div>

  {huarachesItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">HUARACHES</h3>
        <p class="menu-subtitle-text">
          32 cm corn huaraches with refried beans, fresh toppings and your choice of sauce.
        </p>
      </div>
      <div class="menu-grid">
        {huarachesItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}

  {tlacoyosItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">TLACOYOS</h3>
        <p class="menu-subtitle-text">
          Blue corn tlacoyos, stuffed and vacuum sealed so you can finish them at home.
        </p>
      </div>
      <div class="menu-grid">
        {tlacoyosItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}

  {porkCarnitasItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">PORK CARNITAS</h3>
        <p class="menu-subtitle-text">
          Pork carnitas by the kilo and lunch specials with tacos, gorditas and torta.
        </p>
      </div>
      <div class="menu-grid">
        {porkCarnitasItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}

  {grilledPlatterItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">GRILLED PLATTER STYLE CDMX</h3>
        <p class="menu-subtitle-text">
          Grilled platter with chorizo, steak, bacon, pineapple, ham and melted cheese. Serves 1 or 2.
        </p>
      </div>
      <div class="menu-grid">
        {grilledPlatterItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}

  {dessertsItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">DESSERTS</h3>
        <p class="menu-subtitle-text">
          Traditional and artisanal sweets to finish your meal.
        </p>
      </div>
      <div class="menu-grid">
        {dessertsItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}

  {drinksItems.length > 0 && (
    <>
      <div class="menu-subtitle-wrap menu-subtitle-wrap--section">
        <h3 class="menu-subtitle">DRINKS</h3>
        <p class="menu-subtitle-text">
          Sodas and aguas frescas to pair with your antojitos.
        </p>
      </div>
      <div class="menu-grid">
        {drinksItems.map((item) => (
          <MenuItemCard item={item} />
        ))}
      </div>
    </>
  )}
</section>

<style>
  .menu-section {
    padding: 3rem 1.5rem 4rem;
    background: linear-gradient(180deg, #fafafa 0%, var(--color-white) 100%);
  }

  .menu-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .menu-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    color: var(--color-green);
    margin: 0 0 0.5rem;
  }

  .menu-flag {
    font-size: 2rem;
  }

  .menu-subtitle-wrap {
    text-align: center;
    margin: 0 auto 2rem;
    max-width: 640px;
  }

  .menu-subtitle {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-red);
  }

  .menu-subtitle-text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-gray-light);
  }

  .menu-subtitle-wrap--section {
    margin-top: 3rem;
  }

  .menu-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .menu-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .menu-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
