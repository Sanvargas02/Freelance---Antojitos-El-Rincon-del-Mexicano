---
const address = '1605 West 5th Ave, Vancouver, BC';
const phone = '+1 (604) 830 0758';
const mapEmbedUrl = 'https://www.google.com/maps?q=1605+West+5th+Ave,+Vancouver,+BC&output=embed';
---

<section id="location" class="location">
  <div class="location-inner">
    <div class="location-info">
      <h2 class="location-title">Visit us</h2>
      <p class="location-address">{address}</p>
      <p class="location-phone">{phone}</p>
      <a href="https://wa.me/16048300758" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
        💬 Chat with us on WhatsApp
      </a>
    </div>
    <div class="location-map">
      <iframe
        src={mapEmbedUrl}
        width="100%"
        height="300"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Restaurant location"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .location {
    padding: 3rem 1.5rem;
    background: #f5f5f5;
  }

  .location-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    gap: 2rem;
  }

  .location-title {
    font-size: 1.75rem;
    color: var(--color-green);
    margin: 0 0 1rem;
  }

  .location-address,
  .location-phone {
    margin: 0 0 0.5rem;
    color: var(--color-gray);
  }

  .btn-whatsapp {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 1.25rem;
    background: #25d366;
    color: var(--color-white);
    font-weight: 600;
    border-radius: var(--radius);
    transition: background 0.2s, transform 0.15s;
  }

  .btn-whatsapp:hover {
    background: #20bd5a;
    transform: translateY(-1px);
  }

  .location-map {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .location-map iframe {
    display: block;
  }

  @media (min-width: 768px) {
    .location-inner {
      grid-template-columns: 1fr 1.5fr;
    }

    .location-map iframe {
      height: 350px;
    }
  }
</style>
