---
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">Authentic Mexican Street Food</h1>
    <p class="hero-text">
      Family recipes, fresh ingredients, and the flavors of Mexico City in every bite.
    </p>
    <div class="hero-buttons">
      <a href="#menu" class="btn btn-primary">View menu</a>
      <button type="button" class="btn btn-outline" data-order-trigger>Order now</button>
    </div>
  </div>
  <div class="hero-image-wrap">
    <img
      src="/assets/AntijotosElRincondelMexicano_Hero.webp"
      alt="Antojitos El Rincon del Mexicano banner"
      width="1200"
      height="800"
      class="hero-image"
    />
    <div class="hero-badge">4.8 ★ on Google</div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: 2rem;
    padding: 2rem 1.5rem 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-green);
    margin: 0 0 1rem;
  }

  .hero-text {
    margin: 0 0 1.5rem;
    color: var(--color-gray-light);
    max-width: 480px;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius);
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }

  .btn-primary {
    background: var(--color-green);
    color: var(--color-white);
  }

  .btn-primary:hover {
    background: var(--color-green-dark);
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-red);
    border: 2px solid var(--color-red);
  }

  .btn-outline:hover {
    background: var(--color-red);
    color: var(--color-white);
    transform: translateY(-1px);
  }

  .hero-image-wrap {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .hero-image {
    width: 100%;
    height: auto;
  }

  .hero-badge {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-white);
    color: var(--color-green);
    font-weight: 600;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      padding: 3rem 2rem 4rem;
    }

    .hero-content {
      order: 0;
    }

    .hero-image-wrap {
      order: 0;
    }
  }
</style>
