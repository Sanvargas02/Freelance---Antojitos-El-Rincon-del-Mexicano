---
// Replace with your real links
const uberEatsUrl = 'https://www.ubereats.com';
const doorDashUrl = 'https://www.doordash.com';
const whatsappNumber = '16048300758'; // E.164 format, no +
const whatsappMessage = 'Hi, I would like to place an order.';
---

<div id="order-modal" class="modal" aria-hidden="true">
  <div class="modal-backdrop" data-close-modal></div>
  <div class="modal-content">
    <button type="button" class="modal-close" data-close-modal aria-label="Close">×</button>
    <h2 class="modal-title">Order with your favorite app</h2>
    <p class="modal-subtitle" id="modal-dish-name"></p>
    <div class="modal-links">
      <a href={uberEatsUrl} target="_blank" rel="noopener noreferrer" class="modal-link modal-link-uber">
        <span class="modal-link-icon">🍔</span>
        Order on Uber Eats
      </a>
      <a href={doorDashUrl} target="_blank" rel="noopener noreferrer" class="modal-link modal-link-doordash">
        <span class="modal-link-icon">🚗</span>
        Order on DoorDash
      </a>
      <a id="whatsapp-link" href="" target="_blank" rel="noopener noreferrer" class="modal-link modal-link-whatsapp">
        <span class="modal-link-icon">💬</span>
        Order via WhatsApp
      </a>
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s, visibility 0.25s;
  }

  .modal.is-open {
    opacity: 1;
    visibility: visible;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    position: relative;
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    background: var(--color-white);
    border-radius: var(--radius);
    border-top: 4px solid var(--color-red);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }

  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-gray);
    background: none;
    border-radius: 50%;
    transition: background 0.2s, color 0.2s;
  }

  .modal-close:hover {
    background: #f0f0f0;
    color: var(--color-red);
  }

  .modal-title {
    margin: 0 0 0.25rem;
    font-size: 1.5rem;
    color: var(--color-gray);
  }

  .modal-subtitle {
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
    color: var(--color-gray-light);
  }

  .modal-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .modal-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    font-weight: 600;
    border-radius: 8px;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .modal-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow);
  }

  .modal-link-icon {
    font-size: 1.5rem;
  }

  .modal-link-uber {
    background: #06c167;
    color: var(--color-white);
  }

  .modal-link-doordash {
    background: #ff3008;
    color: var(--color-white);
  }

  .modal-link-whatsapp {
    background: #25d366;
    color: var(--color-white);
  }

  @media (max-width: 480px) {
    .modal-content {
      margin-top: auto;
      margin-bottom: 0;
      border-radius: var(--radius) var(--radius) 0 0;
    }
  }
</style>

<script define:vars={{ whatsappNumber, whatsappMessage }}>
  const modal = document.getElementById('order-modal');
  const dishNameEl = document.getElementById('modal-dish-name');
  const whatsappLink = document.getElementById('whatsapp-link');

  const baseWhatsAppUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;

  function openModal(dishTitle = '') {
    if (dishNameEl) dishNameEl.textContent = dishTitle ? `Order: ${dishTitle}` : '';
    const text = dishTitle ? `${whatsappMessage} I would like to order: ${dishTitle}.` : whatsappMessage;
    if (whatsappLink) whatsappLink.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;
    modal?.classList.add('is-open');
    modal?.setAttribute('aria-hidden', 'false');
  }

  function closeModal() {
    modal?.classList.remove('is-open');
    modal?.setAttribute('aria-hidden', 'true');
  }

  document.querySelectorAll('[data-order-trigger]').forEach((el) => {
    el.addEventListener('click', () => {
      const title = el.getAttribute?.('data-dish-title') ?? '';
      openModal(title);
    });
  });

  document.querySelectorAll('[data-close-modal]').forEach((el) => {
    el.addEventListener('click', closeModal);
  });

  modal?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
