---
---

<header class="header">
  <a href="/" class="logo">
    <img src="/assets/logo.png" alt="Logo" class="logo-img" />
    <span>Antojitos El Rincon del Mexicano</span>
  </a>
  <nav class="nav">
    <a href="#menu">Menu</a>
    <a href="#about">About</a>
    <a href="#location">Location</a>
    <a
      href="https://www.ubereats.com/ca/store/antojitos-el-rincon-del-mexicano-1605-west-5th-avenue/l8W0Bh3jXl2xUUJcw4MnxA?diningMode=DELIVERY"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-ubereats"
    >
      Uber Eats
    </a>
    <button type="button" class="btn-order" data-open-cart>View order</button>
  </nav>
  <button type="button" class="menu-toggle" aria-label="Open menu" data-menu-toggle>
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    background: var(--color-white);
    border-bottom: 3px solid var(--color-green);
    box-shadow: var(--shadow);
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-green);
  }

  .logo-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .nav {
    display: none;
    align-items: center;
    gap: 1.5rem;
  }

  .nav.is-open {
    display: flex;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    flex-direction: column;
    padding: 1rem;
    background: var(--color-white);
    border-bottom: 2px solid var(--color-green);
    box-shadow: var(--shadow);
  }

  .nav a {
    font-weight: 600;
    color: var(--color-gray);
    transition: color 0.2s;
  }

  .nav a:hover {
    color: var(--color-red);
  }

  .nav-ubereats {
    color: #06c167;
  }

  .nav-ubereats:hover {
    color: #05a757;
  }

  .btn-order {
    padding: 0.5rem 1.25rem;
    background: var(--color-green);
    color: var(--color-white);
    font-weight: 600;
    border-radius: var(--radius);
    transition: background 0.2s, transform 0.15s;
  }

  .btn-order:hover {
    background: var(--color-green-dark);
    transform: translateY(-1px);
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
  }

  .menu-toggle span {
    width: 24px;
    height: 3px;
    background: var(--color-gray);
    border-radius: 2px;
  }

  @media (min-width: 768px) {
    .nav {
      display: flex;
    }

    .menu-toggle {
      display: none;
    }

    .header {
      padding: 1rem 2rem;
    }

    .logo {
      font-size: 1.5rem;
    }

    .logo-img {
      width: 48px;
      height: 48px;
    }
  }
</style>

<script>
  document.querySelector('[data-menu-toggle]')?.addEventListener('click', () => {
    document.querySelector('.nav')?.classList.toggle('is-open');
  });
</script>
